{
  "ws_server_url": "ws://33.example.internal:8765/ws",
  "agent_id": "windows-32",
  "agent_name": "Hermes Relay",
  "worker_token": "worker-auth-token",
  "heartbeat_interval_seconds": 15,
  "reconnect_interval_seconds": 5,
  "mcp_request_timeout_seconds": 30,
  "allowed_file_roots": [
    "D:/agent_workspace",
    "D:/mcp_work"
  ],
  "powershell_allowlist": [
    "whoami",
    "hostname",
    "ps_version",
    "Get-Process"
  ],
  "allowed_npm_packages": [
    "@modelcontextprotocol/server-filesystem"
  ],
  "allowed_pip_packages": [
    "mcp-server-time"
  ],
  "registry_file": "./servers.json",
  "log_dir": "./logs"
}
